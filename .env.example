# ========================================
# AI Interview - Environment Configuration
# ========================================
# IMPORTANT: Copy this file to .env.local and fill in your values
# NEVER commit .env.local to version control!

# ========================================
# API Keys (REQUIRED)
# ========================================
# Get your Groq API key from: https://console.groq.com
# NOTE: Groq keys start with "gsk_"
GROQ_API_KEY=your_groq_api_key_here

# Get your HuggingFace API key from: https://huggingface.co/settings/tokens
# NOTE: HuggingFace keys start with "hf_"
HF_API_KEY=your_huggingface_api_key_here

# ========================================
# LLM Settings
# ========================================
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_TEMPERATURE=0.7
GROQ_MAX_TOKENS=1024

# ========================================
# Environment Settings
# ========================================
# Options: development, staging, production
ENVIRONMENT=development

# Enable debug mode (set to False in production!)
DEBUG=True

# Logging level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# ========================================
# Application Settings
# ========================================
# Maximum number of interview questions
MAX_QUESTIONS=10

# Audio recording duration per question (seconds)
RECORDING_DURATION=60

# Video capture settings
VIDEO_FPS=30
AUDIO_SAMPLE_RATE=16000

# ========================================
# Directory Paths
# ========================================
# All paths are relative to project root
DOMAINS_DIR=Domains
OUTPUT_DIR=outputs
LOGS_DIR=logs

# ========================================
# Security Settings (CRITICAL FOR PRODUCTION)
# ========================================
# Generate a strong secret key using:
# python -c "import secrets; print(secrets.token_urlsafe(32))"
# NEVER use the default value in production!
SECRET_KEY=CHANGE_THIS_IN_PRODUCTION_GENERATE_STRONG_KEY

# Comma-separated list of allowed hosts
ALLOWED_HOSTS=localhost,127.0.0.1

# Maximum file upload size (MB)
MAX_UPLOAD_SIZE_MB=10

# Maximum video duration (seconds)
MAX_VIDEO_DURATION=3600

# ========================================
# Rate Limiting
# ========================================
# Maximum API calls per minute (per user/session)
MAX_API_CALLS_PER_MINUTE=60

# Maximum upload requests per hour
MAX_UPLOADS_PER_HOUR=10

# ========================================
# Database
# ========================================
# SQLite (default for development)
DATABASE_URL=sqlite:///./interview_data.db

# PostgreSQL (recommended for production)
# DATABASE_URL=postgresql://user:password@localhost:5432/interview_db

# MySQL
# DATABASE_URL=mysql://user:password@localhost:3306/interview_db

# ========================================
# Cheating Detection Thresholds
# ========================================
GAZE_DEVIATION_THRESHOLD=0.3
HEAD_POSE_THRESHOLD=30.0
MOBILE_CONFIDENCE_THRESHOLD=0.5

# ========================================
# Monitoring & Analytics (Optional)
# ========================================
# Sentry DSN for error tracking
# Get from: https://sentry.io
SENTRY_DSN=

# Redis URL for caching (optional)
# REDIS_URL=redis://localhost:6379/0

# Google Analytics ID
GOOGLE_ANALYTICS_ID=

# ========================================
# Email Settings (Optional - for notifications)
# ========================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=

# ========================================
# Cache Settings (Optional)
# ========================================
# Redis URL for caching and session management
REDIS_URL=redis://localhost:6379/0

# Cache TTL in seconds
CACHE_TTL=3600

# ========================================
# Cheating Detection Thresholds
# ========================================
GAZE_DEVIATION_THRESHOLD=0.3
HEAD_POSE_THRESHOLD=30.0
MOBILE_CONFIDENCE_THRESHOLD=0.5

# ========================================
# Production Deployment Settings
# ========================================
# Enable HTTPS redirect
FORCE_HTTPS=False

# CORS allowed origins (comma-separated)
CORS_ORIGINS=http://localhost:3000,http://localhost:8501

# Session timeout (minutes)
SESSION_TIMEOUT=30

# ========================================
# Feature Flags (Optional)
# ========================================
ENABLE_RESUME_PARSING=True
ENABLE_VIDEO_RECORDING=True
ENABLE_EMOTION_ANALYSIS=True
ENABLE_CHEATING_DETECTION=True
ENABLE_REPORT_GENERATION=True

# ========================================
# Notes for Production Deployment:
# ========================================
# 1. Generate a strong SECRET_KEY
# 2. Set DEBUG=False
# 3. Set ENVIRONMENT=production
# 4. Use a production database (PostgreSQL recommended)
# 5. Configure proper ALLOWED_HOSTS
# 6. Set up SENTRY_DSN for error monitoring
# 7. Enable FORCE_HTTPS
# 8. Review and adjust rate limits
# 9. Set up Redis for caching (optional but recommended)
# 10. Configure email settings for notifications
